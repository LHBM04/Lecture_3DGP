# 큐브 메쉬 (8개의 꼭짓점, 12개의 삼각형 페이스)
o Cube

# 꼭짓점 좌표 (Vertex Positions)
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v -0.5  0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5 -0.5
v  0.5  0.5 -0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5

# 텍스처 좌표 (UV Coordinates - 단일 평면 매핑 기준)
vt 0.0 0.0
vt 1.0 0.0
vt 0.0 1.0
vt 1.0 1.0

# 법선 벡터 (Normals)
vn  0.0  0.0  1.0
vn  0.0  1.0  0.0
vn  0.0  0.0 -1.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# 페이스 정의 (Format: v/vt/vn)
# 앞면 (Z+)
f 1/1/1 2/2/1 4/4/1
f 1/1/1 4/4/1 3/3/1
# 윗면 (Y+)
f 3/1/2 4/2/2 6/4/2
f 3/1/2 6/4/2 5/3/2
# 뒷면 (Z-)
f 5/1/3 6/2/3 8/4/3
f 5/1/3 8/4/3 7/3/3
# 아랫면 (Y-)
f 7/1/4 8/2/4 2/4/4
f 7/1/4 2/4/4 1/3/4
# 우측면 (X+)
f 2/1/5 8/2/5 6/4/5
f 2/1/5 6/4/5 4/3/5
# 좌측면 (X-)
f 7/1/6 1/2/6 3/4/6
f 7/1/6 3/4/6 5/3/6